* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    min-height: 100vh;
    color: #fff;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

header {
    text-align: center;
    padding: 30px 0;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 30px;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    background: linear-gradient(135deg, #ffd700, #ff8c00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

header p {
    color: #aaa;
    font-size: 1rem;
}

.controls {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 15px;
    padding: 20px;
    margin-bottom: 20px;
}

.search-box {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;
}

.search-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 1rem;
}

.search-input:focus {
    outline: none;
    border-color: #ffd700;
}

.filters {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.filter-select {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    cursor: pointer;
}

.filter-select option {
    background: #1a1a2e;
}

.btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary {
    background: linear-gradient(135deg, #ffd700, #ff8c00);
    color: #1a1a2e;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 215, 0, 0.3);
}

.btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
}

.btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.stats-bar {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    padding: 12px 20px;
    margin-bottom: 20px;
    text-align: center;
    font-size: 0.9rem;
    color: #ffd700;
}

.brawlers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.brawler-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 15px;
    padding: 20px;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.brawler-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 215, 0, 0.3);
}

/* Ultra-Legendary special card styling */
.ultra-legendary-card {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.15), rgba(255, 69, 0, 0.1));
    border: 2px solid rgba(255, 20, 147, 0.5);
    box-shadow: 0 0 20px rgba(255, 20, 147, 0.2);
}

.ultra-legendary-card:hover {
    border-color: #ff1493;
    box-shadow: 0 0 30px rgba(255, 20, 147, 0.4);
}

.brawler-name {
    font-size: 1.4rem;
    font-weight: bold;
    margin-bottom: 10px;
    color: #ffd700;
}

.ultra-legendary-card .brawler-name {
    text-shadow: 0 0 10px rgba(255, 20, 147, 0.5);
}

.brawler-class {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    font-size: 0.8rem;
    margin-bottom: 15px;
}

.brawler-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    font-size: 0.85rem;
}

.stat {
    display: flex;
    justify-content: space-between;
    padding: 5px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.stat-label {
    color: #aaa;
}

.stat-value {
    font-weight: 600;
    color: #ffd700;
}

.brawler-rarity {
    margin-top: 12px;
    padding-top: 10px;
    text-align: center;
    font-size: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.loading {
    text-align: center;
    padding: 60px;
    font-size: 1.2rem;
    color: #aaa;
    grid-column: 1 / -1;
}

.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
    padding: 20px;
}

#pageInfo {
    font-size: 0.9rem;
    color: #aaa;
}

footer {
    text-align: center;
    padding: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: 40px;
    font-size: 0.8rem;
    color: #666;
}

/* Rarity colors - handled by JavaScript now, but keeping for fallback */
[data-rarity="Ultra-Legendary"] { color: #ff1493; font-weight: bold; text-shadow: 0 0 10px rgba(255, 20, 147, 0.5); }
[data-rarity="Legendary"] { color: #ff4500; }
[data-rarity="Mythic"] { color: #9b59b6; }
[data-rarity="Epic"] { color: #e74c3c; }

@media (max-width: 768px) {
    .brawlers-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }
    
    .filters {
        flex-direction: column;
    }
    
    .search-box {
        flex-direction: column;
    }
}

/* Search hint styling - ADD THIS AT THE VERY BOTTOM */
.search-hint {
    margin-top: 10px;
    font-size: 0.8rem;
    color: #aaa;
    text-align: center;
    transition: all 0.3s ease;
}

.search-hint i, .search-hint em {
    font-style: italic;
}